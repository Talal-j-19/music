# AceStep Music Generator - Environment Variables
# 
# Instructions:
# 1. Copy this file and rename it to .env (remove .example)
# 2. Get your API key from https://fal.ai/dashboard/keys
# 3. Replace 'your_fal_api_key_here' with your actual API key
# 4. (Optional) Get Gemini API key from https://makersuite.google.com/app/apikey
# 5. Save the file
# 6. Restart the server if it's already running

# fal.ai API Key (Required)
FAL_KEY=your_fal_api_key_here

# Google Gemini API Key (Optional - for AI-powered tag generation)
# Get your key from: https://makersuite.google.com/app/apikey
# If not set, the /generate-ai endpoint will use fallback tag generation
GEMINI_API_KEY=your_gemini_api_key_here
